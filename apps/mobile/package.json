{
  "name": "@medicine-tracker/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@medicine-tracker/core": "workspace:*",
    "@react-navigation/native": "^7.0.0",
    "@supabase/supabase-js": "^2.0.0",
    "@tanstack/react-query": "^5.0.0",
    "date-fns": "^4.0.0",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-haptics": "~14.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-sqlite": "~15.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.78.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.0.0",
    "@types/react-native": "~0.73.0",
    "jest": "^29.0.0",
    "jest-expo": "~52.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "~5.8.0"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@medicine-tracker/core$": "<rootDir>/../../packages/core/src/index.ts",
      "^@/(.*)$": "<rootDir>/src/$1",
      "^expo-sqlite$": "<rootDir>/__mocks__/expo-sqlite.ts"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "esModuleInterop": true,
            "skipLibCheck": true,
            "strict": false,
            "jsx": "react"
          },
          "diagnostics": false
        }
      ]
    }
  }
}

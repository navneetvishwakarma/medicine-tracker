{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://placeholder.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "placeholder-anon-key"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://placeholder.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "placeholder-anon-key"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "admin@medicine-tracker.app",
        "ascAppId": "REPLACE_WITH_ASC_APP_ID",
        "appleTeamId": "REPLACE_WITH_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
